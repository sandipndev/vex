#!/bin/sh
# Mock claude CLI for testing vex agent commands.
# Records arguments for verification, outputs canned NDJSON.
# If $VEX_DIR/mock-fail exists, simulate an auth error.
echo "$@" >> "$VEX_DIR/claude-args.log"

if [ -f "$VEX_DIR/mock-fail" ]; then
    echo "Error: authentication required — run 'claude login' first" >&2
    exit 1
fi

echo '{"type":"system","session_id":"mock-session-123"}'
echo '{"type":"content_block_delta","delta":{"type":"text_delta","text":"Hello from mock"}}'
echo '{"type":"message_stop"}'
echo '{"type":"result","session_id":"mock-session-123","result":"Hello from mock"}'
